# Firebase (client — from Firebase Console → Project settings → Web app)
# Use the same Firebase project as the Inigo mobile app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional (standard Firebase web config fields)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Inigo API origin (no trailing slash; paths include /api/…)
# Server-side fallback:
INIGO_API_BASE=
# Required for Studio client calls in the browser (e.g. local Django):
NEXT_PUBLIC_INIGO_API_BASE=

# Public site URL (optional — defaults to https://inigo.now)
SITE_URL=
NEXT_PUBLIC_SITE_URL=
